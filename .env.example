# Copy this file to `.env` and fill in real values for your local environment.

# ==============================================================================
# 1. Security & Encryption
# ==============================================================================

# Face Embedding Encryption Key
# Required for encrypting face embeddings in the database (Privacy by Design).
# Generate your own key using:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FACE_EMBEDDING_FERNET_KEY=changeme_replace_with_generated_fernet_key

# Initial Admin Account
# Used to seed the admin_credentials table if it is empty.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234


# ==============================================================================
# 2. Database & Hardware
# ==============================================================================

# Optional: Database path (default: attendance.db in the current directory)
# DATABASE_PATH=attendance.db

# Optional: Camera device index (default: 0 = built-in webcam, 1 = external USB cam)
# CAMERA_INDEX=0


# ==============================================================================
# 3. AI Pipeline Models (Paths)
# ==============================================================================

# Detector: YuNet (High-performance CNN detector)
FACE_DETECTOR_MODEL_PATH=models/face_detection/face_detection_yunet_2023mar.onnx

# Recognizer: SFace (State-of-the-art face recognition)
FACE_RECOGNITION_MODEL_PATH=models/face_recognition/face_recognition_sface_2021dec.onnx

# Liveness: MiniFASNet (Anti-spoofing)
FACE_ANTISPOOF_ENABLED=true
FACE_ANTISPOOF_MODEL_PATH=models/anti_spoof/best_model_quantized.onnx


# ==============================================================================
# 4. AI Pipeline Thresholds (Seeding)
# ==============================================================================
# NOTE: These values are used to seed the database settings table on the FIRST run.
# Subsequent changes should be made through the application settings UI.

# Liveness detection confidence threshold (0.0 to 1.0)
# Higher = stricter (rejects more photos/screens, but may reject real faces).
FACE_ANTISPOOF_CONFIDENCE_THRESHOLD=0.8

# Face recognition similarity threshold (0.0 to 1.0)
# Higher = stricter (requires a closer match to a registered profile).
FACE_SIMILARITY_THRESHOLD=0.6

# Copy this file to `.env` and fill in real secrets when running locally.

# Face Embedding Encryption Key
# Required for encrypting face embeddings (per SRS Section 4.2 - Privacy by Design)
# Generate your own key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Then replace the placeholder below with your generated key
FACE_EMBEDDING_FERNET_KEY=changeme_replace_with_generated_fernet_key

# Initial admin account (used for first-run bootstrap when admin table is empty)
# Replace these defaults before deploying to production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234
# Optional: ADMIN_ROLE=enrollment_admin | attendance_admin | super_admin
# ADMIN_ROLE=super_admin

# Optional: Database path (default: attendance.db in current directory)
# DATABASE_PATH=attendance.db

# Face Anti-Spoofing Configuration
# Enable or disable real-time face anti-spoofing liveness detection
FACE_ANTISPOOF_ENABLED=true

# Path to the MiniFASNetV2-SE quantized ONNX model
# Download via: python tools/download_antispoof_models.py
FACE_ANTISPOOF_MODEL_PATH=models/anti_spoof/best_model_quantized.onnx

# Liveness detection confidence threshold (0.0-1.0)
FACE_ANTISPOOF_CONFIDENCE_THRESHOLD=0.8